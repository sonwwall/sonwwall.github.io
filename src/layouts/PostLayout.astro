---
import PostLeft from "@components/stalux/posts/postLeft.astro";
import PostContent from "@components/stalux/posts/postContent.astro";
import PostRight from "@components/stalux/posts/postRight.astro";
import PostNavigation from "@components/stalux/posts/postNavigation.astro";
import PostCC from "@components/stalux/posts/postCC.astro";
import WalineComment from "@components/stalux/posts/WalineComment.astro";
import KatexStyle from "@components/stalux/posts/KatexStyle.astro";
import PhotoSwipeStyle from "@components/stalux/posts/PhotoSwipeStyle.astro";
import { getCollection } from "astro:content";
import layoutStyle from "@styles/components/posts/postLayout.module.css";

interface Props {
    title: string;
    date?: string;
    updated?: string;
    readingTime?: string;
    wordCount?: number;
    tags?: string[];
    categories?: string[];
    headings?: Array<{ depth: number; slug: string; text: string }>;
    author?: string;
    authorAvatar?: string;
    prev?: { url: string; title: string };
    next?: { url: string; title: string };
    cc?: string;
    hasMermaid?: boolean;
    hasKatex?: boolean;
    hasImage?: boolean;
}

const props = Astro.props as Props;
const tags = props.tags ?? [];
const categories = props.categories ?? [];
const headings = props.headings ?? [];
const author = props.author ?? "Author";

// 获取 Waline 配置
const stalux = (await getCollection("config"))[0].data;
const commentEnabled = stalux?.comment?.enabled ?? false;
const walineConfig = stalux?.comment?.waline;
---

{props.hasKatex && <KatexStyle />}
{props.hasImage && <PhotoSwipeStyle />}

<div class={layoutStyle.postLayout}>
    <div class={layoutStyle.container}>
        <!-- Left Sidebar -->
        <PostLeft author={author} authorAvatar={props.authorAvatar} />

        <!-- Main Content -->
        <PostContent
            title={props.title}
            date={props.date}
            updated={props.updated}
            readingTime={props.readingTime}
            wordCount={props.wordCount}
            hasImage={props.hasImage}
        >
            <slot />
            <PostCC
                title={props.title}
                author={author}
                url={Astro.url.href}
                cc={props.cc}
            />
            <PostNavigation prev={props.prev} next={props.next} />
            {
                commentEnabled && walineConfig?.serverURL && (
                    <WalineComment
                        serverURL={walineConfig.serverURL}
                        path={Astro.url.pathname}
                        title={props.title}
                        lang={walineConfig.lang}
                        locale={(walineConfig as any).locale}
                        emoji={walineConfig.emoji}
                        reaction={walineConfig.reaction}
                        meta={walineConfig.meta as any}
                        wordLimit={walineConfig.wordLimit}
                        pageSize={walineConfig.pageSize}
                        login={(walineConfig as any).login}
                        recaptchaV3Key={(walineConfig as any).recaptchaV3Key}
                        turnstileKey={(walineConfig as any).turnstileKey}
                        dark={(walineConfig as any).dark}
                        noCopyright={(walineConfig as any).noCopyright}
                        commentSorting={(walineConfig as any).commentSorting}
                        imageUploader={(walineConfig as any).imageUploader}
                        highlighter={(walineConfig as any).highlighter}
                        texRenderer={(walineConfig as any).texRenderer}
                        search={(walineConfig as any).search}
                    />
                )
            }
        </PostContent>

        <!-- Right Sidebar -->
        <PostRight headings={headings} tags={tags} categories={categories} />
    </div>
</div>

{
    props.hasMermaid && (
        <script>
            import mermaid from "mermaid";
            const renderMermaid = async () => {
                if (document.querySelector(".mermaid")) {
                    mermaid.initialize({
                        startOnLoad: false,
                        theme: "dark",
                    });
                    await mermaid.run();
                }
            };
            document.addEventListener("astro:page-load", renderMermaid);
        </script>
    )
}
