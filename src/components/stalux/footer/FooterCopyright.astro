---
interface Props {
    author?: string;
    startYear?: number;
}

const props = Astro.props as Props;

const currentYear = new Date().getFullYear();
const copyrightYear =
    props.startYear && props.startYear < currentYear
        ? `${props.startYear}-${currentYear}`
        : currentYear;
---

<div class="copyright">
    <span>&copy; {copyrightYear} {props.author || ""}. 保留权利.</span>
</div>

<style>
    .copyright {
        font-weight: 500;
        display: flex;
        gap: 0.3em;
        justify-content: center;
        flex-wrap: wrap;
    }

    .copyright span {
        margin: 0;
    }
</style>
